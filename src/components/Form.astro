<form method="POST" id="form">
  <div
    class="flex flex-col w-lg gap-6 bg-white rounded-lg shadow-md mx-auto font-fallback p-10"
  >
    <h2 class="mx-auto font-bold text-2xl text-gray-800">
      ¿Tienes dudas? Te escribimos ahora
    </h2>

    <section class="flex flex-col gap-2">
      <label for="name" class="text-gray-700"
        >Nombre de Contacto o Empresa:</label
      >
      <div
        class="flex items-center border border-gray-300 rounded-lg bg-gray-50"
      >
        <span class="px-3 text-gray-500">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path
              d="M10 0a10 10 0 1 0 10 10A10.011 10.011 0 0 0 10 0Zm0 5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Zm0 13a8.949 8.949 0 0 1-4.951-1.488A3.987 3.987 0 0 1 9 13h2a3.987 3.987 0 0 1 3.951 3.512A8.949 8.949 0 0 1 10 18Z"
            ></path>
          </svg>
        </span>
        <input
          type="text"
          id="website-admin"
          placeholder="Nombre de Contacto o Empresa"
          class="flex-1 bg-transparent py-2.5 px-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400 rounded-r-lg"
        />
      </div>
    </section>

    <section class="flex flex-col gap-2">
      <label for="email" class="text-gray-700">Correo:</label>
      <div
        class="flex items-center border border-gray-300 rounded-lg bg-gray-50"
      >
        <span class="px-3 text-gray-500">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 16">
            <path
              d="m10.036 8.278 9.258-7.79A1.979 1.979 0 0 0 18 0H2A1.987 1.987 0 0 0 .641.541l9.395 7.737Z"
            ></path>
            <path
              d="M11.241 9.817c-.36.275-.801.425-1.255.427-.428 0-.845-.138-1.187-.395L0 2.6V14a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V2.5l-8.759 7.317Z"
            ></path>
          </svg>
        </span>
        <input
          type="email"
          id="email"
          placeholder="Correo"
          class="flex-1 bg-transparent py-2.5 px-3 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400 rounded-r-lg"
        />
      </div>
    </section>

    <section class="flex flex-col gap-2">
      <label for="phone" class="text-gray-700">Teléfono:</label>
      <input
        type="tel"
        id="phone"
        placeholder="123-456-789"
        pattern="[0-9]{3}-[0-9]{3}-[0-9]{3}"
        required
        class="w-full bg-gray-50 border border-gray-300 text-gray-800 placeholder-gray-400 text-sm rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-blue-400"
      />
      <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
    </section>

    <section class="flex">
      <button
        type="submit"
        class="bg-[#1ACC8D] w-full drop-shadow-2xl rounded-2xl py-2 px-16 text-white font-semibold hover:bg-[#17b97e] transition-all"
      >
        Enviar
      </button>
    </section>

    <div id="result"></div>
  </div>

  <script is:inline src="@/utils/scriptForm.js"></script>
</form>
